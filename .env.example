# ═══════════════════════════════════════════════════════════════════════════════
# POLYMARKET BTC 15-MINUTE TRADING BOT - ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# 
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit your .env file to version control!
# ═══════════════════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────────────────────────
# CRITICAL: TEST MODE
# ─────────────────────────────────────────────────────────────────────────────────
# When true, uses virtual balance and simulates trades
# ALWAYS start with true until you fully understand the bot
TEST_MODE=true


# ─────────────────────────────────────────────────────────────────────────────────
# POLYMARKET API CREDENTIALS (Required for LIVE trading)
# ─────────────────────────────────────────────────────────────────────────────────
# Get these from: https://polymarket.com/settings (API section)
# 
# Steps to get API credentials:
#   1. Go to polymarket.com and log in
#   2. Navigate to Settings → API
#   3. Create new API credentials
#   4. Copy the API Key, Secret (base64 encoded), and Passphrase
#
# These enable L1 authentication (reading balance, positions, order history)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=


# ─────────────────────────────────────────────────────────────────────────────────
# WALLET CREDENTIALS (Required for LIVE trading - L2 authentication)
# ─────────────────────────────────────────────────────────────────────────────────
# Your Polygon/Ethereum wallet for signing orders
# These enable L2 authentication (placing and cancelling orders)
#
# ⚠️ SECURITY WARNINGS:
#   - Never share your private key with anyone!
#   - Never commit this file to git!
#   - Use a dedicated trading wallet with limited funds
#   - Add .env to your .gitignore file
#
# WALLET_PRIVATE_KEY: Export from MetaMask or other wallet
#   - Must start with "0x"
#   - Example: 0x1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef
#
# WALLET_ADDRESS: Your public wallet address
#   - Example: 0x742d35Cc6634C0532925a3b844Bc9e7595f3bD77
#
# Make sure this wallet:
#   1. Has USDC on Polygon network for trading
#   2. Has small amount of MATIC for gas fees
#   3. Is connected/approved on Polymarket
WALLET_PRIVATE_KEY=0x
WALLET_ADDRESS=0x


# ─────────────────────────────────────────────────────────────────────────────────
# BINANCE API (OPTIONAL)
# ─────────────────────────────────────────────────────────────────────────────────
# Not required - public endpoints work for price data
# Only needed if you want higher rate limits
BINANCE_API_KEY=
BINANCE_API_SECRET=


# ─────────────────────────────────────────────────────────────────────────────────
# BALANCE & SIZING
# ─────────────────────────────────────────────────────────────────────────────────
# Starting virtual balance for test mode (default: 100)
INITIAL_VIRTUAL_BALANCE=100.0

# Bet size as percentage of balance (default: 0.03 = 3%)
BET_SIZE_PERCENT=0.03

# Minimum bet size in USD (default: 1.0)
MIN_BET_SIZE_USD=1.0

# Maximum bet size in USD - cap exposure (default: 10.0)
MAX_BET_SIZE_USD=10.0

# Stop trading when balance falls below this (default: 10.0)
MIN_BALANCE_TO_TRADE=10.0


# ─────────────────────────────────────────────────────────────────────────────────
# SAFETY LIMITS (Recommended for LIVE trading)
# ─────────────────────────────────────────────────────────────────────────────────
# Daily loss limit as percentage of daily starting balance (default: 0.20 = 20%)
# Set to 0 to disable
DAILY_LOSS_LIMIT_PERCENT=0.20

# Daily loss limit in absolute USD (default: 0 = use percentage only)
# If set > 0, this takes precedence when reached first
DAILY_LOSS_LIMIT_USD=0.0

# Max consecutive losses before pausing (default: 10, set to 0 to disable)
MAX_CONSECUTIVE_LOSSES=10

# Cooldown after hitting loss limit in seconds (default: 3600 = 1 hour)
LOSS_LIMIT_COOLDOWN_SECONDS=3600

# Maximum trades per day (default: 100, set to 0 to disable)
MAX_TRADES_PER_DAY=100


# ─────────────────────────────────────────────────────────────────────────────────
# MARKET FILTERS
# ─────────────────────────────────────────────────────────────────────────────────
# Maximum market age in seconds to consider (default: 60)
MAX_MARKET_AGE_SECONDS=60

# Minimum liquidity required in USD (default: 500)
MIN_LIQUIDITY_USD=500.0

# Maximum combined Yes+No price (spread check, default: 1.05)
MAX_SPREAD_COMBINED=1.05


# ─────────────────────────────────────────────────────────────────────────────────
# SIGNAL THRESHOLDS
# ─────────────────────────────────────────────────────────────────────────────────
# BTC price change threshold to detect bias (default: 0.10%)
BTC_BIAS_THRESHOLD_PERCENT=0.10

# Lookback period in minutes (default: 3)
BTC_LOOKBACK_MINUTES=3


# ─────────────────────────────────────────────────────────────────────────────────
# PROBABILITY & EDGE
# ─────────────────────────────────────────────────────────────────────────────────
# Fair probability for mild bias (default: 0.52 = 52%)
MILD_BIAS_FAIR_PROB=0.52

# Fair probability for strong bias (default: 0.55 = 55%)
STRONG_BIAS_FAIR_PROB=0.55

# Threshold for strong vs mild bias (default: 0.20%)
STRONG_BIAS_THRESHOLD_PERCENT=0.20

# Minimum edge required to trade (default: 0.02 = 2%)
MIN_EDGE_THRESHOLD=0.02


# ─────────────────────────────────────────────────────────────────────────────────
# TIMING & RATE LIMITS
# ─────────────────────────────────────────────────────────────────────────────────
# How often to scan for markets in seconds (default: 15)
SCAN_INTERVAL_SECONDS=15

# Cooldown between trades in seconds (default: 60)
TRADE_COOLDOWN_SECONDS=60

# Max API calls per minute (default: 30)
MAX_API_CALLS_PER_MINUTE=30


# ─────────────────────────────────────────────────────────────────────────────────
# FEES & SLIPPAGE ESTIMATES
# ─────────────────────────────────────────────────────────────────────────────────
# Estimated fee per trade (default: 0.01 = 1%)
ESTIMATED_FEE_PERCENT=0.01

# Estimated slippage (default: 0.005 = 0.5%)
ESTIMATED_SLIPPAGE_PERCENT=0.005


# ─────────────────────────────────────────────────────────────────────────────────
# ORDER EXECUTION (LIVE MODE)
# ─────────────────────────────────────────────────────────────────────────────────
# Maximum time to wait for order fill in seconds (default: 60)
ORDER_FILL_TIMEOUT=60

# Maximum slippage allowed for order placement (default: 0.02 = 2%)
MAX_ORDER_SLIPPAGE=0.02

# Cancel unfilled orders after timeout (default: true)
CANCEL_UNFILLED_ORDERS=true


# ─────────────────────────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────────────────────────
# Trade log file path (default: trades.csv)
TRADE_LOG_FILE=trades.csv

# Enable verbose console output (default: true)
VERBOSE_LOGGING=true
